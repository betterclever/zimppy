{
  "$schema": "https://opencode.ai/config.json",
  "model": "vp-openai/gpt-5.4",
  "small_model": "vp-openai/gpt-5.4-mini",
  "provider": {
    "vp-openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "VibeProxy OpenAI",
      "options": {
        "baseURL": "http://host.docker.internal:8317/v1",
        "apiKey": "dummy-not-used"
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT 5.4 (VP)",
          "limit": { "context": 272000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "variants": {
            "medium": { "reasoningEffort": "medium", "reasoningSummary": "auto", "textVerbosity": "medium" }
          }
        },
        "gpt-5.4-mini": {
          "name": "GPT 5.4 Mini (VP)",
          "limit": { "context": 272000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "variants": {
            "medium": { "reasoningEffort": "medium", "reasoningSummary": "auto", "textVerbosity": "medium" }
          }
        }
      }
    }
  },
  "mcp": {
    "zimppy": {
      "type": "local",
      "command": ["node", "/app/node_modules/.bin/tsx", "/app/examples/mcp-server/src/server.ts"],
      "environment": {
        "SERVER_WALLET_CONFIG": "/app/config/server-wallet.json",
        "ZCASH_RPC_ENDPOINT": "https://zcash-testnet-zebrad.gateway.tatum.io",
        "MPP_SERVER": "http://host.docker.internal:3180"
      },
      "timeout": 10000
    }
  }
}
