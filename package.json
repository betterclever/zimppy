{
  "name": "zimppy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "node scripts/lint.mjs",
    "test": "tsx --test packages/zimppy-ts/test/**/*.test.ts apps/*/test/**/*.test.ts 2>/dev/null || true"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
